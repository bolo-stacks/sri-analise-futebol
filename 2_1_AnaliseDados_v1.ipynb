   "source": [
    "import pandas as pd\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "df = pd.read_csv('documentos.csv', sep=';')\n",
    "\n",
    "tamanhos = df['documento'].str.len()\n",
    "\n",
    "plt.hist(tamanhos)\n",
    "plt.title('Distribuição dos documentos')\n",
    "plt.xlabel('Quantidade de caracteres')\n",
    "plt.ylabel('Frequência')\n",
    "plt.show()\n"
   ]
  }
